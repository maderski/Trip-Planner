rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isPlannerId(plannerId) {
      return plannerId.matches('^[a-f0-9]{64}$');
    }

    match /planners/{plannerId} {
      allow list: if false;
      allow get, create, update: if isPlannerId(plannerId);
      allow delete: if false;
    }
  }
}
